{
  "name": "blip-list-generator",
  "version": "1.0.0",
  "description": "CLI para gerar scripts de lista interativa e regex para plataforma Blip",
  "main": "dist/index.js",
  "bin": {
    "blip-list-generator": "dist/index.js"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "package": "npm run build && npm run package:all",
    "package:all": "npm run package:win && npm run package:linux && npm run package:macos",
    "package:win": "pkg dist/index.js --targets node18-win-x64 --output bin/blip-list-generator-win.exe",
    "package:linux": "pkg dist/index.js --targets node18-linux-x64 --output bin/blip-list-generator-linux",
    "package:macos": "pkg dist/index.js --targets node18-macos-x64 --output bin/blip-list-generator-macos"
  },
  "keywords": ["blip", "cli", "whatsapp", "bot"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "pkg": {
    "scripts": ["dist/**/*.js"],
    "assets": [],
    "targets": ["node18"],
    "outputPath": "bin"
  }
}
